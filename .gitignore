# ==============================================================================
# Enterprise AI Monorepo .gitignore
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Python & Caches
# ------------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyc
*.pyo
*.pyd
*$py.class
*.so
.python-version
.ipynb_checkpoints/
.Python
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
.hypothesis/
.mypy_cache/
.ruff_cache/

# ------------------------------------------------------------------------------
# 2. Virtual Environments
# ------------------------------------------------------------------------------
venv/
.venv/
.env_python/
pip-log.txt
pip-delete-this-directory.txt

# ------------------------------------------------------------------------------
# 3. Environment Files
# ------------------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
!.env.example

# ------------------------------------------------------------------------------
# 4. IDE / Editor / OS Metadata
# ------------------------------------------------------------------------------
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
.Spotlight-V100/
.Trashes/
ehthumbs.db

# ------------------------------------------------------------------------------
# 5. Node.js & Frontend
# ------------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.next/
out/
.swc/
.cache-loader/
.eslintcache
.parcel-cache/

# ------------------------------------------------------------------------------
# 6. Docker
# ------------------------------------------------------------------------------
.docker/
docker-compose.override.yml
*.sock

# ------------------------------------------------------------------------------
# 7. Terraform
# ------------------------------------------------------------------------------
.terraform/
*.tfstate
*.tfstate.*
crash.log
crash.*.log
*.tfvars
*.tfvars.json
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc

# ------------------------------------------------------------------------------
# 8. Databases
# ------------------------------------------------------------------------------
*.sqlite
*.sqlite3
*.db
*.db3
*.s3db
*.sl3
dump.rdb
appendonly.aof

# ------------------------------------------------------------------------------
# 9. Logs & Temporary Files
# ------------------------------------------------------------------------------
logs/*
!logs/.gitkeep
!logs/README.md
*.log
tmp/*
!tmp/.gitkeep
!tmp/README.md
temp/*
!temp/.gitkeep
!temp/README.md
*.tmp
*.bak

# ------------------------------------------------------------------------------
# 9b. Runtime Uploads & Storage
# ------------------------------------------------------------------------------
uploads/*
!uploads/.gitkeep
!uploads/README.md
storage/uploads/*
!storage/uploads/.gitkeep
!storage/uploads/README.md
storage/temp/*
!storage/temp/.gitkeep
!storage/temp/README.md
storage/cache/*
!storage/cache/.gitkeep
!storage/cache/README.md
storage/quarantine/*
!storage/quarantine/.gitkeep
!storage/quarantine/README.md

# ------------------------------------------------------------------------------
# 10. Medical Datasets (DICOM/NIfTI)
# ------------------------------------------------------------------------------
datasets/*
!datasets/.gitkeep
!datasets/README.md
*.dcm
*.nii
*.nii.gz
*.mha
*.mhd
*.raw
*.zraw
*.nrrd

# ------------------------------------------------------------------------------
# 11. Trained Models & Checkpoints
# ------------------------------------------------------------------------------
*.pt
*.pth
*.h5
*.hdf5
*.keras
*.onnx
*.pb
*.ckpt
*.safetensors
*.bin
*.pkl
*.joblib
*.tflite
*.mlmodel
*.engine

# ------------------------------------------------------------------------------
# 12. Experiment Outputs & ML Artifacts
# ------------------------------------------------------------------------------
experiments/*
!experiments/.gitkeep
!experiments/README.md
outputs/*
!outputs/.gitkeep
!outputs/README.md
results/*
!results/.gitkeep
!results/README.md
mlruns/*
!mlruns/.gitkeep
!mlruns/README.md
mlartifacts/*
!mlartifacts/.gitkeep
!mlartifacts/README.md
mlflow.db
ray_results/*
!ray_results/.gitkeep
!ray_results/README.md
tb_logs/*
!tb_logs/.gitkeep
!tb_logs/README.md
wandb/*
!wandb/.gitkeep
!wandb/README.md
.wandb/*
!.wandb/.gitkeep
!.wandb/README.md
tensorboard/*
!tensorboard/.gitkeep
!tensorboard/README.md
*.tfevents.*

# ------------------------------------------------------------------------------
# 13. Generated Reports & Visualizations
# ------------------------------------------------------------------------------
reports/*
!reports/.gitkeep
!reports/README.md
visualizations/*
!visualizations/.gitkeep
!visualizations/README.md

# ------------------------------------------------------------------------------
# 14. Local Configuration
# ------------------------------------------------------------------------------
*.local.yml
*.local.yaml
*.local.json
.openclaude-profile.json

# ------------------------------------------------------------------------------
# 15. Kubernetes Local Config
# ------------------------------------------------------------------------------
kubeconfig
*.kubeconfig

# ------------------------------------------------------------------------------
# 16. Profiling
# ------------------------------------------------------------------------------
*.prof
*.profraw
*.profdata

# ------------------------------------------------------------------------------
# 17. Secrets & Certificates
# ------------------------------------------------------------------------------
*.pem
*.key
*.crt
*.csr
*.p12
*.pfx

# ------------------------------------------------------------------------------
# 18. Generated API Clients
# ------------------------------------------------------------------------------
generated/*
!generated/.gitkeep
!generated/README.md
openapi/*
!openapi/.gitkeep
!openapi/README.md

# ------------------------------------------------------------------------------
# 19. Explicitly Tracked Files
# ------------------------------------------------------------------------------
!uv.lock
!pyproject.toml
!.gitignore
!.gitattributes
!.editorconfig
!.pre-commit-config.yaml
!README.md
