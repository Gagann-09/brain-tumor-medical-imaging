/visualizations/
/reports/

# ── 7. Logs ──────────────────────────────────────────────────────────────────
/logs/
*.log
*.tmp
*.bak

# ── 8. Docker & Terraform ────────────────────────────────────────────────────
.docker/
docker-compose.override.yml
*.sock
.terraform/
