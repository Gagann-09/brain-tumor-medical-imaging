# ==============================================================================
# ARM-GAN Platform .gitignore
# ==============================================================================

# ── 1. Python & Caches ───────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.eggs/
*.whl
build/
dist/
sdist/
develop-eggs/
.installed.cfg
.Python
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
.hypothesis/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/
.python-version
venv/
.venv/

# ── 2. Node.js & Frontend ────────────────────────────────────────────────────
node_modules/
.next/
out/
.swc/
.eslintcache
.cache-loader/
.parcel-cache/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── 3. IDE, Editor & OS ──────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
Desktop.ini
.Spotlight-V100/
.Trashes/
.openclaude-profile.json

# ── 4. Secrets & Certificates ────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.crt
*.csr
*.p12
*.pfx

# ── 5. Runtime Data ──────────────────────────────────────────────────────────
# Datasets — only README.md is tracked
datasets/*
!datasets/README.md

# Trained models — only README.md is tracked
models/*
!models/README.md
*.pt
*.pth
*.h5
*.hdf5
*.keras
*.onnx
*.pb
*.ckpt
*.safetensors
*.bin
*.pkl
*.joblib
*.tflite
*.mlmodel
*.engine

# Medical imaging files
*.dcm
*.nii
*.nii.gz
*.mha
*.mhd
*.raw
*.zraw
*.nrrd

# Outputs, uploads, storage, temp
/outputs/
/backend/outputs_val/
/results/
/uploads/
/storage/cache/
/storage/quarantine/
/storage/temp/
/storage/uploads/
/temp/
/tmp/
/generated/
/openapi/
/test_inference_output/
/test_robustness_output/
/test_xai_output/

# ── 6. ML Tracking & Experiment Outputs ──────────────────────────────────────
/experiments/
/mlruns/
/mlartifacts/
mlflow.db
/ray_results/
/tb_logs/
/tensorboard/
*.tfevents.*
/wandb/
